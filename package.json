{
  "name": "vs-preview",
  "displayName": "1ureka 的 VS Code 預覽套件",
  "author": "1ureka",
  "publisher": "1ureka",
  "description": "取代 VS Code 內建的多媒體資源預覽，提供專業級的檢視體驗與便捷的操作工具。",
  "version": "0.1.4",
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "type": "module",
  "engines": {
    "vscode": "^1.106.1"
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "1ureka.vscode.preview.image",
        "displayName": "圖片檢視器",
        "priority": "default",
        "selector": [
          {
            "filenamePattern": "*.{jpg,jpeg,png,gif,bmp,webp,tiff,tif}"
          }
        ]
      }
    ]
  },
  "scripts": {
    "build": "tsx src/build.ts",
    "compile": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.43",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.106.1",
    "colord": "^2.9.3",
    "esbuild": "^0.28.0",
    "fs-extra": "^11.3.4",
    "iconv-lite": "^0.7.2",
    "oxlint": "^1.59.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-zoom-pan-pinch": "^3.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zustand": "^5.0.12"
  }
}
